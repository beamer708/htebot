# ─────────────────────────────────────────────────────────────
# HowToERLC Bot — Environment Variables
# Copy this file to .env and fill in every value before starting.
# ─────────────────────────────────────────────────────────────

# ── Discord Bot ──────────────────────────────────────────────
# Your bot's token from discord.com/developers → Applications → Bot → Token
BOT_TOKEN=your_discord_bot_token_here

# ── Web API ──────────────────────────────────────────────────
# Port the Express server listens on (default 3000)
PORT=3000

# Secret key that the HowToERLC website must send in the X-API-SECRET header
# Use any long random string — e.g. output of: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=your_random_api_secret_here

# URL of the HowToERLC website (used for CORS allow-list)
WEBSITE_URL=https://howtoerlc.xyz

# ── Discord OAuth2 (Admin Panel) ─────────────────────────────
# From discord.com/developers → Applications → OAuth2 → General
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# The redirect URI you registered in Discord's OAuth2 settings
# Must exactly match: https://yourdomain.com/auth/discord/callback
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/discord/callback

# Any long random string for signing session cookies
# e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_random_session_secret_here

# ── AI Assistant (Claude) ────────────────────────────────────
# Your Anthropic API key from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set to "true" to restrict /api/ai-chat to requests with a valid X-BETA-TOKEN
AI_BETA_MODE=false

# Comma-separated list of valid beta-tester tokens (used when AI_BETA_MODE=true)
# e.g.: token1,token2,token3
AI_BETA_TOKENS=

# ── Maintenance Mode ─────────────────────────────────────────
# Set to "true" to return 503 on all public API routes (admin panel still works)
MAINTENANCE_MODE=false

# ── Node Environment ─────────────────────────────────────────
# "production" enables strict CORS; "development" allows all origins
NODE_ENV=development
